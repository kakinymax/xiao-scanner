<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>XIAO ENV Data Scanner</title>
  <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    :root {
      --bg: #0f172a;
      --panel: rgba(30, 41, 59, 0.8);
      --accent: #10b981;
      --text: #f8fafc;
    }
    body {
      margin: 0; padding: 0;
      background-color: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', -apple-system, sans-serif;
      display: flex; flex-direction: column;
      align-items: center; 
      min-height: 100vh;
      min-height: 100dvh;
      background: radial-gradient(circle at top, #1e293b, var(--bg));
    }
    .container {
      width: 100%; max-width: 450px;
      padding: 30px 20px; box-sizing: border-box;
      display: flex; flex-direction: column; gap: 20px;
      z-index: 10;
      margin: auto;
    }
    .header { text-align: center; }
    .header h1 {
      margin: 0; font-size: 1.6rem;
      background: linear-gradient(to right, #34d399, #3b82f6);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 1px;
    }
    .header p { color: #94a3b8; font-size: 0.9rem; margin-top: 5px; }

    /* フェーズ切り替え用スタイル */
    .view-section { display: none; width: 100%; }
    .view-section.active { display: block; }

    .scanner-box {
      position: relative;
      width: 100%; aspect-ratio: 1;
      background: #000;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.7);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    video { width: 100%; height: 100%; object-fit: cover; }
    .overlay {
      position: absolute; top: 0; left: 0; right: 0; bottom: 0;
      box-shadow: inset 0 0 0 4px rgba(16, 185, 129, 0.4);
      border-radius: 20px;
      pointer-events: none;
      display: flex; align-items: center; justify-content: center;
    }
    .scan-line {
      width: 90%; height: 2px;
      background: var(--accent);
      box-shadow: 0 0 15px var(--accent);
      animation: scan 2s linear infinite alternate;
      position: absolute;
    }
    @keyframes scan { 0% { top: 5%; opacity: 0.8; } 100% { top: 95%; opacity: 1; } }
    .focus-hint {
      position: absolute; bottom: 10px; left: 0; right: 0;
      text-align: center; font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.6);
      pointer-events: none;
    }
    .focus-ring {
      position: absolute; width: 60px; height: 60px;
      border: 2px solid #fbbf24; border-radius: 8px;
      pointer-events: none; display: none;
      transform: translate(-50%, -50%);
      animation: focus-flash 0.4s ease-out;
    }
    @keyframes focus-flash {
      0% { opacity: 1; transform: translate(-50%, -50%) scale(1.3); }
      100% { opacity: 0.8; transform: translate(-50%, -50%) scale(1); }
    }
    .progress-panel {
      background: var(--panel);
      padding: 20px; border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      margin-top: 15px;
    }
    .progress-text { display: flex; justify-content: space-between; margin-bottom: 15px; font-weight: bold; font-size: 0.95rem; }
    .blocks { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; }
    .block { flex: 1; height: 12px; min-width: 15px; max-width: 30px; background: rgba(255, 255, 255, 0.1); border-radius: 4px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .block.active { background: var(--accent); box-shadow: 0 0 10px var(--accent); transform: scale(1.1); }
    
    button {
      background: linear-gradient(135deg, #10b981, #059669);
      color: #fff; border: none; padding: 15px 20px;
      border-radius: 12px; font-weight: bold;
      font-size: 1.1rem; cursor: pointer;
      box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
      transition: transform 0.1s, box-shadow 0.2s;
      width: 100%; letter-spacing: 0.5px;
    }
    button:active { transform: scale(0.97); }
    button:disabled { background: #475569; color: #94a3b8; box-shadow: none; cursor:not-allowed; }
    
    #canvas { display: none; }
    #chart-container { width: 100%; background: var(--panel); padding: 15px; border-radius: 16px; box-sizing: border-box; border: 1px solid rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); }
    
    .di-legend { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-top: 15px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.1); font-size: 0.75rem; color: #94a3b8; }
    .di-legend-item { display: flex; align-items: center; gap: 4px; }
    .di-box { width: 10px; height: 10px; border-radius: 2px; }
    .di-box.danger { background: rgba(239, 68, 68, 0.4); }
    .di-box.alert { background: rgba(245, 158, 11, 0.4); }
    .di-box.warn { background: rgba(252, 211, 77, 0.4); }
    .di-box.comfort { background: rgba(16, 185, 129, 0.2); }
    .di-box.cold { background: rgba(59, 130, 246, 0.4); }
    
    .di-summary-table { width: 100%; margin-top: 15px; border-collapse: collapse; font-size: 0.8rem; text-align: center; }
    .di-summary-table th, .di-summary-table td { padding: 8px; border: 1px solid rgba(255,255,255,0.1); }
    .di-summary-table th { background: rgba(0,0,0,0.2); color: #94a3b8; font-weight: normal; }
    
    .btn-group-vertical { display: flex; flex-direction: column; gap: 12px; width: 100%; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>XIAO ENV DECODER</h1>
      <p id="sub-header">取得モードを選択してください</p>
    </div>

    <div id="view-setup" class="view-section active">
      <div class="btn-group-vertical">
        <button id="btn-start">📷 カメラでQRスキャン</button>
        <button id="btn-ble" style="background: linear-gradient(135deg, #3b82f6, #1d4ed8);">📶 BLEで通常同期</button>
        <button id="btn-ai-log" style="background: linear-gradient(135deg, #8b5cf6, #6d28d9); font-size: 0.9rem;">🤖 全AIログを取得 (1ヶ月分)</button>
      </div>
    </div>

    <div id="view-active" class="view-section">
      <div class="scanner-box" id="scanner-container">
        <video id="video" autoplay playsinline muted></video>
        <div class="overlay">
          <div class="scan-line" id="scan-line"></div>
          <div class="focus-hint" id="focus-hint">👆 タップでフォーカス</div>
          <div class="focus-ring" id="focus-ring"></div>
        </div>
        <canvas id="canvas"></canvas>
      </div>
      <div class="progress-panel">
        <div class="progress-text">
          <span id="status">準備中...</span>
        </div>
        <div class="blocks" id="blocks"></div>
      </div>
      <button onclick="location.reload()" style="background: #475569; margin-top: 15px; font-size: 0.9rem;">✖ キャンセルして戻る</button>
    </div>

    <div id="view-result" class="view-section">
      <div id="chart-container">
        <canvas id="chart"></canvas>
      </div>
      <div id="download-area" style="margin-top: 20px; display: flex; flex-direction: column; gap: 10px;">
        </div>
      <button onclick="location.reload()" style="background: #1e293b; margin-top: 20px; border: 1px solid #475569;">🔄 最初に戻る</button>
    </div>
  </div>

  <script>
    const video = document.getElementById("video");
    const canvas = document.getElementById("canvas");
    const ctx = canvas.getContext("2d", { willReadFrequently: true });
    const blocksEl = document.getElementById("blocks");
    const statusEl = document.getElementById("status");
    const subHeader = document.getElementById("sub-header");
    const btnStart = document.getElementById("btn-start");
    const btnBle = document.getElementById("btn-ble");
    const btnAiLog = document.getElementById("btn-ai-log");
    const focusRing = document.getElementById("focus-ring");
    const focusHint = document.getElementById("focus-hint");
    
    let activeStream = null;
    let scanning = false;
    let expectedPages = 0;
    let receivedPayloads = [];
    let isComplete = false;
    let envChart = null;

    // 画面遷移用関数
    function switchView(viewId, subText) {
      document.querySelectorAll('.view-section').forEach(el => el.classList.remove('active'));
      document.getElementById(viewId).classList.add('active');
      if (subText) subHeader.innerText = subText;
    }

    // カメラ起動処理
    btnStart.addEventListener("click", async () => {
      switchView('view-active', 'QRコードをスキャンしてください');
      try {
        const constraints = { 
          video: { facingMode: "environment", width: { ideal: 1920 }, height: { ideal: 1080 }, advanced: [{ focusMode: "continuous" }] }
        };
        const stream = await navigator.mediaDevices.getUserMedia(constraints);
        activeStream = stream;
        video.srcObject = stream;
        
        video.addEventListener("click", async (e) => {
          if (!activeStream) return;
          const track = activeStream.getVideoTracks()[0];
          const rect = video.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width;
          const y = (e.clientY - rect.top) / rect.height;
          focusRing.style.left = (e.clientX - rect.left) + "px";
          focusRing.style.top = (e.clientY - rect.top) + "px";
          focusRing.style.display = "block";
          setTimeout(() => { focusRing.style.display = "none"; }, 800);
          try {
            await track.applyConstraints({ advanced: [{ focusMode: "single-shot", pointOfInterest: { x, y } }] });
          } catch (_) {}
        });

        setTimeout(() => { focusHint.style.opacity = "0"; }, 3000);
        requestAnimationFrame(tick);
        scanning = true;
        statusEl.innerText = "読み取り中... 📱";
        blocksEl.innerHTML = "";
      } catch (err) {
        alert("カメラエラー: " + err.message);
        location.reload();
      }
    });

    // BLE同期処理
    btnBle.addEventListener("click", async () => {
      switchView('view-active', 'BLEデバイスを探しています...');
      try {
        const SERVICE_UUID = "4fafc201-1fb5-459e-8fcc-c5c9c331914b";
        const CHAR_RX_UUID = "beb5483e-36e1-4688-b7f5-ea07361b26a8";
        const CHAR_TX_UUID = "beb5483e-36e1-4688-b7f5-ea07361b26a9";

        const bleDevice = await navigator.bluetooth.requestDevice({
          filters: [{ namePrefix: "XIAO" }],
          optionalServices: [SERVICE_UUID]
        });

        statusEl.innerText = "接続中...";
        const server = await bleDevice.gatt.connect();
        const service = await server.getPrimaryService(SERVICE_UUID);
        const rxChar = await service.getCharacteristic(CHAR_RX_UUID);
        const txChar = await service.getCharacteristic(CHAR_TX_UUID);

        // 時刻同期
        const ts = Math.floor(Date.now() / 1000).toString();
        await rxChar.writeValue(new TextEncoder().encode(ts));
        statusEl.innerText = "時刻同期完了。データ受信中...";

        await txChar.startNotifications();
        let bleCompLen = 0;
        let bleBuffer = [];
        
        txChar.addEventListener("characteristicvaluechanged", (e) => {
          const value = new Uint8Array(e.target.value.buffer);
          if (bleBuffer.length === 0) bleCompLen = 6 + (value[0] * 3);
          for (let i=0; i<value.length; i++) bleBuffer.push(value[i]);
          statusEl.innerText = `受信中... ${bleBuffer.length} / ${bleCompLen} bytes`;
          if (bleBuffer.length >= bleCompLen && !isComplete) {
            isComplete = true;
            processComplete(new Uint8Array(bleBuffer));
          }
        });
      } catch(err) {
        alert("BLEエラー: " + err.message);
        location.reload();
      }
    });

    // AIログ取得処理
    btnAiLog.addEventListener("click", async () => {
      switchView('view-active', 'AIログを取得中...');
      try {
        const SERVICE_UUID = "4fafc201-1fb5-459e-8fcc-c5c9c331914b";
        const CHAR_RX_UUID = "beb5483e-36e1-4688-b7f5-ea07361b26a8";
        const CHAR_TX_UUID = "beb5483e-36e1-4688-b7f5-ea07361b26a9";

        const bleDevice = await navigator.bluetooth.requestDevice({
          filters: [{ namePrefix: "XIAO" }],
          optionalServices: [SERVICE_UUID]
        });

        const server = await bleDevice.gatt.connect();
        const service = await server.getPrimaryService(SERVICE_UUID);
        const rxChar = await service.getCharacteristic(CHAR_RX_UUID);
        const txChar = await service.getCharacteristic(CHAR_TX_UUID);

        alert("⚠️ AIログの転送には数分かかる場合があります。\n画面を閉じずにお待ちください。");
        await rxChar.writeValue(new TextEncoder().encode("GET_AI_LOG"));
        await txChar.startNotifications();
        
        let aiBuffer = [];
        let startTime = Date.now();
        
        txChar.addEventListener("characteristicvaluechanged", (e) => {
          const value = new Uint8Array(e.target.value.buffer);
          if (value.length === 3 && value[0] === 69 && value[1] === 79 && value[2] === 70) {
            txChar.stopNotifications();
            processAILogComplete(new Uint8Array(aiBuffer));
            return;
          }
          for (let i=0; i<value.length; i++) aiBuffer.push(value[i]);
          statusEl.innerText = `受信中... ${aiBuffer.length} bytes (${Math.floor((Date.now()-startTime)/1000)}秒経過)`;
        });
      } catch(err) {
        alert("AIログエラー: " + err.message);
        location.reload();
      }
    });

    function processAILogComplete(comp) {
      switchView('view-result', 'AIログ受信完了');
      const dlArea = document.getElementById("download-area");
      dlArea.innerHTML = `<button id="btn-dl-bin" style="background: linear-gradient(135deg, #8b5cf6, #6d28d9);">🤖 AI用バイナリ(.bin)を保存</button>`;
      
      const blob = new Blob([comp], { type: "application/octet-stream" });
      const url = URL.createObjectURL(blob);
      
      document.getElementById("btn-dl-bin").onclick = () => {
        const a = document.createElement("a");
        a.style.display = "none";
        a.href = url;
        a.download = `ai_env_log_${Math.floor(Date.now()/1000)}.bin`;
        document.body.appendChild(a);
        a.click();
        setTimeout(() => { document.body.removeChild(a); }, 100);
      };
    }

    function initBlocks(total) {
      if (expectedPages === total) return;
      expectedPages = total;
      receivedPayloads = new Array(total).fill(null);
      blocksEl.innerHTML = "";
      for(let i=0; i<total; i++) {
        let b = document.createElement("div");
        b.className = "block"; b.id = "block-" + i;
        blocksEl.appendChild(b);
      }
    }

    function tick() {
      if (!scanning) return;
      if (video.readyState === video.HAVE_ENOUGH_DATA && !isComplete) {
        canvas.width = Math.min(video.videoWidth, 600);
        canvas.height = canvas.width * (video.videoHeight / video.videoWidth);
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
        let imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        let code = jsQR(imageData.data, imageData.width, imageData.height, { inversionAttempts: "attemptBoth" });

        if (code && code.binaryData && code.binaryData.length >= 2) {
          let page = code.binaryData[0];
          let total = code.binaryData[1];
          if (total > 0 && total < 50) {
            initBlocks(total);
            if (page < total && !receivedPayloads[page]) {
              receivedPayloads[page] = Array.from(code.binaryData.slice(2));
              document.getElementById("block-" + page).classList.add("active");
              let count = receivedPayloads.filter(x => x !== null).length;
              statusEl.innerText = `✅ ${count} / ${total} ページ完了`;
              if (count === total) { isComplete = true; processComplete(); }
            }
          }
        }
      }
      if (!isComplete) requestAnimationFrame(tick);
    }

    function processComplete(directBuffer = null) {
      scanning = false;
      if (video.srcObject) video.srcObject.getTracks().forEach(t => t.stop());
      switchView('view-result', 'データ解析完了');
      
      const dlArea = document.getElementById("download-area");
      dlArea.innerHTML = `<button id="btn-dl">💾 CSVをダウンロード</button>`;
      
      let comp;
      if (directBuffer) {
        comp = directBuffer;
      } else {
        let allBytes = [];
        for(let i=0; i<expectedPages; i++) allBytes.push(...receivedPayloads[i]);
        comp = new Uint8Array(allBytes);
      }

      let history_count = comp[0];
      let view = new DataView(comp.buffer);
      let ts = view.getUint32(2, true); 
      
      let labels = [], temp_data = [], hum_data = [], di_data = [];
      let csv = "Timestamp,Temperature(C),Humidity(%),DiscomfortIndex\n";
      
      for(let i=0; i<history_count; i++) {
        let t_raw = comp[6 + i];
        let h_raw = comp[6 + history_count + i];
        let di_raw = comp[6 + history_count * 2 + i];
        
        let temp = (t_raw / 5.0) + 10.0;
        let hum = h_raw / 2.55;
        let di = (di_raw / 4.0) + 30.0;
        
        let pTime = new Date((ts - (history_count - 1 - i) * 12 * 60) * 1000);
        let pad = n => ('0'+n).slice(-2);
        let timeStr = `${pTime.getFullYear()}-${pad(pTime.getMonth()+1)}-${pad(pTime.getDate())} ${pad(pTime.getHours())}:${pad(pTime.getMinutes())}:${pad(pTime.getSeconds())}`;
        
        labels.push(`${pad(pTime.getHours())}:${pad(pTime.getMinutes())}`);
        temp_data.push(temp.toFixed(1));
        hum_data.push(hum.toFixed(1));
        di_data.push(di);
        csv += `${timeStr},${temp.toFixed(1)},${hum.toFixed(1)},${di.toFixed(1)}\n`;
      }

      // グラフ描画
      if (envChart) envChart.destroy();
      const ctxChart = document.getElementById("chart").getContext("2d");
      envChart = new Chart(ctxChart, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            { label: '温度 (°C)', data: temp_data, borderColor: '#10b981', yAxisID: 'y', tension: 0.3 },
            { label: '湿度 (%)', data: hum_data, borderColor: '#3b82f6', yAxisID: 'y1', tension: 0.3 }
          ]
        },
        options: {
          scales: {
            y: { type: 'linear', position: 'left', ticks: { color: '#10b981' } },
            y1: { type: 'linear', position: 'right', ticks: { color: '#3b82f6' }, grid: { drawOnChartArea: false } }
          }
        }
      });

      document.getElementById("btn-dl").onclick = () => {
        const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url; a.download = `env_data_${ts}.csv`;
        document.body.appendChild(a); a.click();
        setTimeout(() => { document.body.removeChild(a); }, 100);
      };
    }
  </script>
</body>
</html>
